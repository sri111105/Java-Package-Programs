class Solution {
    int majorityElement(int arr[]) {
        HashMap<Integer,Integer> map=new HashMap<>();
        
        for(int num:arr){
            map.put(num,map.getOrDefault(num,0)+1);
            
             if(map.get(num)>arr.length/2){
            return num;
          }
        
        }
        return -1;
    }
}

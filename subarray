import java.util.*;
class Main {
    public static void main(String[] args) {
      int arr[]={4,3,4,3};
      int k=2;
      int ans=0;
     for(int i=0;i<arr.length;i++){
         HashMap<Integer,Integer> m=new HashMap<>();
         for(int j=i;j<arr.length;j++){
             m.put(arr[j],m.getOrDefault(arr[j],0)+1);
             
             if(m.get(arr[j])>=k){
                 ans++;
             }
         }
     }
     System.out.print(ans);
    }
}
